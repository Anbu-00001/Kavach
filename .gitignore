# ============================================================================
# Kavach — repository root .gitignore
#
# App-subtree ignores live in app/.gitignore and app/android/.gitignore (the
# standard Flutter/Android sets). This file covers the repo root, the Python
# ML pipeline in core/, the Rust crate, and cross-cutting editor/OS/build noise.
#
# IMPORTANT — assets are committed ON PURPOSE via Git LFS (see .gitattributes:
# *.onnx, *.onnx.data, *.safetensors). The bundled models and audio the app
# ships — *.onnx, *.so, *.zip, *.mp3, *.wav, *.safetensors — are TRACKED.
# Do NOT add blanket extension ignores for those here, or a fresh clone will be
# missing the model weights and warning clips it needs to run.
# ============================================================================

# ── Build output (regenerated) ──────────────────────────────────────────────
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
*.g.dart
.gradle/
.cxx/
local.properties
# Rust / Cargo
target/

# ── Python (core/ ML + eval pipeline) ───────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.pytest_cache/
.ipynb_checkpoints/

# ── Large training artifacts that are NOT shipped ──────────────────────────
# Retrain candidate (~90 MB safetensors) kept locally only for A/B comparison;
# the shipped weights live in core/model/intent and app/assets/model.
core/model/intent_candidate/

# ── Packaged binaries (rebuilt from source) ─────────────────────────────────
*.apk
*.aab

# ── Secrets / signing — never commit ────────────────────────────────────────
*.keystore
*.jks
key.properties
.env
.env.*

# ── Editors / IDEs ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# ── Claude Code local state (a shared .claude/settings.json may be committed) ─
.claude/settings.local.json

# ── OS cruft ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs & scratch ──────────────────────────────────────────────────────────
*.log
*.tmp
